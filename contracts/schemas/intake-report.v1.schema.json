{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/EffortlessMetrics/shiplog/contracts/schemas/intake-report.v1.schema.json",
  "title": "Shiplog intake report v1",
  "type": "object",
  "additionalProperties": false,
  "propertyNames": {
    "$ref": "#/$defs/non_secret_field_name"
  },
  "required": [
    "schema_version",
    "run_id",
    "readiness",
    "config_path",
    "out_dir",
    "run_dir",
    "packet_path",
    "period",
    "window",
    "reports",
    "included_sources",
    "skipped_sources",
    "source_decisions",
    "source_freshness",
    "repair_sources",
    "curation_notes",
    "good",
    "needs_attention",
    "evidence_debt",
    "top_fixups",
    "journal_suggestions",
    "share_commands",
    "next_commands",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "readiness": {
      "type": "string",
      "enum": [
        "Ready for review",
        "Needs curation",
        "Needs evidence",
        "Needs repair"
      ]
    },
    "config_path": {
      "$ref": "#/$defs/path"
    },
    "out_dir": {
      "$ref": "#/$defs/path"
    },
    "run_dir": {
      "$ref": "#/$defs/path"
    },
    "packet_path": {
      "$ref": "#/$defs/path"
    },
    "period": {
      "type": [
        "string",
        "null"
      ]
    },
    "window": {
      "$ref": "#/$defs/window"
    },
    "reports": {
      "$ref": "#/$defs/reports"
    },
    "included_sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/included_source"
      }
    },
    "skipped_sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/skipped_source"
      }
    },
    "source_decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source_decision"
      }
    },
    "source_freshness": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source_freshness"
      }
    },
    "repair_sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/repair_source"
      }
    },
    "repair_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/repair_item"
      }
    },
    "packet_quality": {
      "$ref": "#/$defs/packet_quality"
    },
    "curation_notes": {
      "$ref": "#/$defs/string_array"
    },
    "good": {
      "$ref": "#/$defs/string_array"
    },
    "needs_attention": {
      "$ref": "#/$defs/string_array"
    },
    "evidence_debt": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_debt"
      }
    },
    "top_fixups": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fixup"
      }
    },
    "journal_suggestions": {
      "$ref": "#/$defs/string_array"
    },
    "share_commands": {
      "$ref": "#/$defs/string_array"
    },
    "next_commands": {
      "$ref": "#/$defs/string_array"
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    }
  },
  "$defs": {
    "non_secret_field_name": {
      "type": "string",
      "not": {
        "pattern": "[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll]|[Aa][Pp][Ii]_?[Kk][Ee][Yy]|[Kk][Ee][Yy]_?[Vv][Aa][Ll][Uu][Ee]"
      }
    },
    "object_base": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/non_secret_field_name"
      }
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "string_array": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_key": {
      "type": "string",
      "enum": [
        "github",
        "gitlab",
        "jira",
        "linear",
        "manual",
        "json",
        "git",
        "unknown"
      ]
    },
    "window": {
      "allOf": [
        {
          "$ref": "#/$defs/object_base"
        },
        {
          "required": [
            "since",
            "until",
            "label"
          ],
          "properties": {
            "since": {
              "type": "string",
              "format": "date"
            },
            "until": {
              "type": "string",
              "format": "date"
            },
            "label": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "reports": {
      "allOf": [
        {
          "$ref": "#/$defs/object_base"
        },
        {
          "required": [
            "markdown",
            "json"
          ],
          "properties": {
            "markdown": {
              "$ref": "#/$defs/path"
            },
            "json": {
              "$ref": "#/$defs/path"
            }
          }
        }
      ]
    },
    "included_source": {
      "allOf": [
        {
          "$ref": "#/$defs/object_base"
        },
        {
          "required": [
            "source",
            "event_count",
            "summary"
          ],
          "properties": {
            "source": {
              "type": "string",
              "minLength": 1
            },
            "source_key": {
              "$ref": "#/$defs/source_key"
            },
            "source_label": {
              "type": "string",
              "minLength": 1
            },
            "event_count": {
              "type": "integer",
              "minimum": 0
            },
            "summary": {
              "type": "string"
            }
          }
        }
      ]
    },
    "skipped_source": {
      "allOf": [
        {
          "$ref": "#/$defs/object_base"
        },
        {
          "required": [
            "source",
            "reason"
          ],
          "properties": {
            "source": {
              "type": "string",
              "minLength": 1
            },
            "source_key": {
              "$ref": "#/$defs/source_key"
            },
            "source_label": {
              "type": "string",
              "minLength": 1
            },
            "reason": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "source_decision": {
      "allOf": [
        {
          "$ref": "#/$defs/object_base"
        },
        {
          "required": [
            "source",
            "decision",
            "reason",
            "hint_label",
            "hint_lines"
          ],
          "properties": {
            "source": {
              "type": "string",
              "minLength": 1
            },
            "source_key": {
              "$ref": "#/$defs/source_key"
            },
            "source_label": {
              "type": "string",
              "minLength": 1
            },
            "decision": {
              "type": "string",
              "enum": [
                "included",
                "skipped"
              ]
            },
            "reason": {
              "type": "string"
            },
            "hint_label": {
              "type": [
                "string",
                "null"
              ]
            },
            "hint_lines": {
              "$ref": "#/$defs/string_array"
            }
          }
        }
      ]
    },
    "source_freshness": {
      "allOf": [
        {
          "$ref": "#/$defs/object_base"
        },
        {
          "required": [
            "source",
            "status",
            "cache_hits",
            "cache_misses"
          ],
          "properties": {
            "source": {
              "type": "string",
              "minLength": 1
            },
            "source_key": {
              "$ref": "#/$defs/source_key"
            },
            "source_label": {
              "type": "string",
              "minLength": 1
            },
            "status": {
              "type": "string",
              "enum": [
                "fresh",
                "cached",
                "stale",
                "skipped",
                "unavailable"
              ]
            },
            "cache_hits": {
              "type": "integer",
              "minimum": 0
            },
            "cache_misses": {
              "type": "integer",
              "minimum": 0
            },
            "observed_at": {
              "type": "string"
            },
            "reason": {
              "type": "string"
            }
          }
        }
      ]
    },
    "repair_source": {
      "allOf": [
        {
          "$ref": "#/$defs/object_base"
        },
        {
          "required": [
            "source",
            "reason",
            "commands"
          ],
          "properties": {
            "source": {
              "type": "string",
              "minLength": 1
            },
            "source_key": {
              "$ref": "#/$defs/source_key"
            },
            "source_label": {
              "type": "string",
              "minLength": 1
            },
            "kind": {
              "type": "string",
              "enum": [
                "missing_token",
                "missing_identity",
                "invalid_filter",
                "bad_instance_url",
                "auth_rejected",
                "rate_limited",
                "network_timeout",
                "partial_results",
                "cache_replay",
                "local_source_unavailable",
                "missing_file",
                "setup_required"
              ]
            },
            "reason": {
              "type": "string",
              "minLength": 1
            },
            "commands": {
              "$ref": "#/$defs/string_array"
            }
          }
        }
      ]
    },
    "repair_item": {
      "allOf": [
        {
          "$ref": "#/$defs/object_base"
        },
        {
          "required": [
            "repair_id",
            "repair_key",
            "kind",
            "reason",
            "action",
            "clears_when",
            "receipt_refs"
          ],
          "properties": {
            "repair_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^repair_[a-z0-9_]+$"
            },
            "repair_key": {
              "type": "string",
              "minLength": 1
            },
            "source_key": {
              "$ref": "#/$defs/source_key"
            },
            "source_label": {
              "type": "string",
              "minLength": 1
            },
            "kind": {
              "type": "string",
              "enum": [
                "manual_evidence_missing",
                "source_skipped_configuration",
                "source_freshness_stale",
                "source_cached_only",
                "evidence_debt_open",
                "share_redaction_required",
                "artifact_missing_or_unopened"
              ]
            },
            "reason": {
              "type": "string",
              "minLength": 1
            },
            "action": {
              "$ref": "#/$defs/repair_action"
            },
            "clears_when": {
              "type": "string",
              "minLength": 1
            },
            "receipt_refs": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/repair_receipt_ref"
              }
            }
          }
        }
      ]
    },
    "repair_action": {
      "allOf": [
        {
          "$ref": "#/$defs/object_base"
        },
        {
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "journal_add",
                "configure_source",
                "rerun_intake",
                "open_artifact",
                "no_safe_action"
              ]
            },
            "command": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "repair_receipt_ref": {
      "allOf": [
        {
          "$ref": "#/$defs/object_base"
        },
        {
          "required": [
            "field"
          ],
          "properties": {
            "field": {
              "type": "string",
              "enum": [
                "source_decisions",
                "source_freshness",
                "repair_sources",
                "needs_attention",
                "evidence_debt",
                "top_fixups",
                "journal_suggestions",
                "next_commands",
                "actions",
                "artifacts"
              ]
            },
            "source_key": {
              "$ref": "#/$defs/source_key"
            }
          }
        }
      ]
    },
    "packet_quality": {
      "allOf": [
        {
          "$ref": "#/$defs/object_base"
        },
        {
          "required": [
            "packet_readiness",
            "evidence_strength",
            "claim_candidates",
            "share_posture"
          ],
          "properties": {
            "packet_readiness": {
              "$ref": "#/$defs/packet_readiness"
            },
            "evidence_strength": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/evidence_strength"
              }
            },
            "claim_candidates": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/claim_candidate"
              }
            },
            "share_posture": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/share_posture"
              }
            }
          }
        }
      ]
    },
    "packet_readiness": {
      "allOf": [
        {
          "$ref": "#/$defs/object_base"
        },
        {
          "required": [
            "status",
            "summary",
            "reasons",
            "next_actions"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "ready",
                "ready_with_caveats",
                "needs_evidence",
                "needs_context",
                "blocked"
              ]
            },
            "summary": {
              "type": "string",
              "minLength": 1
            },
            "reasons": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/packet_readiness_reason"
              }
            },
            "next_actions": {
              "$ref": "#/$defs/string_array"
            }
          }
        }
      ]
    },
    "packet_readiness_reason": {
      "allOf": [
        {
          "$ref": "#/$defs/object_base"
        },
        {
          "required": [
            "kind",
            "summary",
            "receipt_refs"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "minLength": 1
            },
            "summary": {
              "type": "string",
              "minLength": 1
            },
            "receipt_refs": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/quality_receipt_ref"
              }
            }
          }
        }
      ]
    },
    "evidence_strength": {
      "allOf": [
        {
          "$ref": "#/$defs/object_base"
        },
        {
          "required": [
            "scope",
            "status",
            "reason",
            "receipt_refs"
          ],
          "properties": {
            "scope": {
              "type": "string",
              "minLength": 1
            },
            "status": {
              "type": "string",
              "enum": [
                "strong",
                "partial",
                "manual_only",
                "source_skipped",
                "needs_context"
              ]
            },
            "reason": {
              "type": "string",
              "minLength": 1
            },
            "receipt_refs": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/quality_receipt_ref"
              }
            }
          }
        }
      ]
    },
    "quality_receipt_ref": {
      "allOf": [
        {
          "$ref": "#/$defs/object_base"
        },
        {
          "required": [
            "field"
          ],
          "properties": {
            "field": {
              "type": "string",
              "enum": [
                "included_sources",
                "skipped_sources",
                "source_decisions",
                "source_freshness",
                "repair_sources",
                "repair_items",
                "good",
                "needs_attention",
                "evidence_debt",
                "top_fixups",
                "journal_suggestions",
                "share_commands",
                "next_commands",
                "actions",
                "artifacts"
              ]
            },
            "source_key": {
              "$ref": "#/$defs/source_key"
            },
            "repair_key": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "claim_candidate": {
      "allOf": [
        {
          "$ref": "#/$defs/object_base"
        },
        {
          "required": [
            "claim_id",
            "title",
            "evidence_strength",
            "supporting_receipt_refs",
            "missing_context_prompts",
            "safe_profiles"
          ],
          "properties": {
            "claim_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^claim_[a-z0-9_]+$"
            },
            "title": {
              "type": "string",
              "minLength": 1
            },
            "evidence_strength": {
              "type": "string",
              "enum": [
                "strong",
                "partial",
                "manual_only",
                "source_skipped",
                "needs_context"
              ]
            },
            "supporting_repair_keys": {
              "$ref": "#/$defs/string_array"
            },
            "supporting_sources": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/source_key"
              }
            },
            "supporting_receipt_refs": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/quality_receipt_ref"
              }
            },
            "missing_context_prompts": {
              "$ref": "#/$defs/string_array"
            },
            "safe_profiles": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/share_profile"
              }
            },
            "caveats": {
              "$ref": "#/$defs/string_array"
            },
            "related_artifacts": {
              "$ref": "#/$defs/string_array"
            },
            "suppressed_profiles": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/share_profile"
              }
            }
          }
        }
      ]
    },
    "share_posture": {
      "allOf": [
        {
          "$ref": "#/$defs/object_base"
        },
        {
          "required": [
            "profile",
            "status",
            "included",
            "removed",
            "blocked",
            "next_actions",
            "receipt_refs"
          ],
          "properties": {
            "profile": {
              "$ref": "#/$defs/share_profile"
            },
            "status": {
              "type": "string",
              "enum": [
                "ready",
                "ready_with_caveats",
                "blocked",
                "not_generated"
              ]
            },
            "included": {
              "$ref": "#/$defs/string_array"
            },
            "removed": {
              "$ref": "#/$defs/string_array"
            },
            "blocked": {
              "$ref": "#/$defs/string_array"
            },
            "next_actions": {
              "$ref": "#/$defs/string_array"
            },
            "receipt_refs": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/quality_receipt_ref"
              }
            }
          }
        }
      ]
    },
    "share_profile": {
      "type": "string",
      "enum": [
        "manager",
        "public"
      ]
    },
    "evidence_debt": {
      "allOf": [
        {
          "$ref": "#/$defs/object_base"
        },
        {
          "required": [
            "severity",
            "kind",
            "summary",
            "detail",
            "next_step"
          ],
          "properties": {
            "severity": {
              "type": "string",
              "enum": [
                "info",
                "warning",
                "blocking"
              ]
            },
            "kind": {
              "type": "string",
              "enum": [
                "missing-source",
                "partial-coverage",
                "coverage-warning",
                "incomplete-query",
                "manual-context",
                "no-selected-receipts",
                "thin-workstream",
                "large-misc-workstream",
                "code-only-workstream",
                "ticket-only-workstream",
                "manual-only-workstream",
                "too-many-selected-receipts",
                "broad-workstream",
                "workstream-validation"
              ]
            },
            "summary": {
              "type": "string",
              "minLength": 1
            },
            "detail": {
              "type": [
                "string",
                "null"
              ]
            },
            "next_step": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        }
      ]
    },
    "fixup": {
      "allOf": [
        {
          "$ref": "#/$defs/object_base"
        },
        {
          "required": [
            "title",
            "detail",
            "command"
          ],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^fixup_[a-z0-9_]+$"
            },
            "kind": {
              "type": "string",
              "enum": [
                "validate_workstreams",
                "repair_sources",
                "split_misc_workstream",
                "manual_context",
                "select_receipts",
                "trim_receipts",
                "split_broad_workstream",
                "ticket_context",
                "code_context",
                "manual_only_workstream",
                "thin_workstream"
              ]
            },
            "title": {
              "type": "string",
              "minLength": 1
            },
            "detail": {
              "type": [
                "string",
                "null"
              ]
            },
            "command": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "action": {
      "allOf": [
        {
          "$ref": "#/$defs/object_base"
        },
        {
          "required": [
            "id",
            "kind",
            "label",
            "command",
            "writes",
            "risk"
          ],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^action_[a-z0-9_]+$"
            },
            "kind": {
              "type": "string",
              "enum": [
                "repair_source",
                "fixup",
                "share_manager",
                "share_public",
                "next_command"
              ]
            },
            "label": {
              "type": "string",
              "minLength": 1
            },
            "command": {
              "type": "string",
              "minLength": 1
            },
            "writes": {
              "type": "boolean"
            },
            "risk": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high"
              ]
            }
          }
        }
      ]
    },
    "artifact": {
      "allOf": [
        {
